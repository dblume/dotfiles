{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "_COMMENT": "ANTHROPIC_BASE_URL and ANTHROPIC_AUTH_TOKEN may be set elsewhere",
    "ANTHROPIC_MODEL": "claude-4.6-sonnet",
    "ANTHROPIC_SMALL_FAST_MODEL": "claude-4.5-haiku",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-4.5-haiku",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-4.6-sonnet",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": true,
    "DISABLE_TELEMETRY": true,
    "DISABLE_BUG_COMMAND": true,
    "DISABLE_ERROR_REPORTING": true
  },
  "permissions": {
    "deny": [
      "Read(.env*)",
      "Bash(git commit:*)"
    ],
    "allow": [
      "Read(README.md)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "autoUpdatesChannel": "stable",
  "alwaysThinkingEnabled": true
}
